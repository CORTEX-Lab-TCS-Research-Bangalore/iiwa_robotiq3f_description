                    <!-- ===== GRIPPER NESTED HERE ===== -->
                    <body name="palm" pos="0 0 0.11" quat="0.7071 0.7071 0 0" childclass="robotiq">
                      <inertial pos="0 0 0" mass="1.3" diaginertia="1.5e-3 1.5e-3 1.5e-3"/>
                      <geom class="robotiq_visual" type="mesh" mesh="rq_palm"/>

                      <body name="finger_1_link_0" pos="-0.0455 0.0214 0.036" quat="-2.59838e-06 0.706825 0.707388 2.59631e-06">
                        <inertial pos="0.02 0 0" mass="0.05" diaginertia="3.3e-6 3.3e-6 3.3e-6"/>
                        <joint name="palm_finger_1_joint" axis="0 1 0" range="-0.1784 0.192"/>
                        <geom class="robotiq_visual" pos="0.02 0 0" type="mesh" mesh="rq_link_0"/>
                        <body name="finger_1_link_1" pos="0.02 0 0">
                          <inertial pos="0.025 -0.014 0" mass="0.15" diaginertia="1.0e-5 3.6e-5 3.6e-5"/>
                          <joint name="finger_1_joint_1" axis="0 0 1" range="0.0495 1.2218"/>
                          <geom class="robotiq_visual" pos="0.05 -0.028 0" quat="0.96639 0 0 -0.257081" type="mesh" mesh="rq_link_1"/>
                          <body name="finger_1_link_2" pos="0.05 -0.028 0" quat="0.96639 0 0 -0.257081">
                            <inertial pos="0.02 0 0.0075" mass="0.15" diaginertia="1.0e-5 3.6e-5 3.6e-5"/>
                            <joint name="finger_1_joint_2" axis="0 0 1" range="0 1.5708"/>
                            <geom class="robotiq_visual" pos="0.039 0 0.0075" type="mesh" mesh="rq_link_2"/>
                            <body name="finger_1_link_3" pos="0.039 0 0">
                              <inertial pos="0.01 0 0" mass="0.05" diaginertia="3.3e-6 3.3e-6 3.3e-6"/>
                              <joint name="finger_1_joint_3" axis="0 0 1" range="-1.2217 -0.0523"/>
                              <geom class="robotiq_visual" quat="0.96639 0 0 0.257081" type="mesh" mesh="rq_link_3"/>
                              <geom name="f1_tip" class="robotiq_fingertip" type="capsule" fromto="0 0 0  0.03 0 0" size="0.008"/>
