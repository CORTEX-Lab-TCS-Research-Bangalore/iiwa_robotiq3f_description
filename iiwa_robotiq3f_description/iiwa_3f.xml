                          </body>
                        </body>
                      </body>

                      <body name="finger_2_link_0" pos="-0.0455 0.0214 -0.036" quat="-2.59838e-06 0.706825 0.707388 2.59631e-06">
                        <inertial pos="0.02 0 0" mass="0.05" diaginertia="3.3e-6 3.3e-6 3.3e-6"/>
