        <geom class="iiwa_visual" mesh="link_1"/>
        <geom class="iiwa_collision" size="0.08" pos="0 0 -0.0005"/>
        <geom class="iiwa_collision" size="0.075" pos="0.01 -0.025 0.0425"/>
        <geom class="iiwa_collision" size="0.075" pos="-0.01 -0.025 0.0425"/>
        <geom class="iiwa_collision" size="0.07" pos="0.01 -0.045 0.1025"/>
